# ─── Server ───────────────────────────────────────────────────────────────────
PORT=4000
NODE_ENV=development
ALLOWED_ORIGINS=http://localhost:3000

# ─── PostgreSQL ───────────────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=aeti_onboarding
DB_USER=aeti
DB_PASSWORD=aeti_dev
DB_ENCRYPTION_KEY=                         # 32+ char random secret — encrypts EIN, bank account, ABA at rest (pgcrypto)

# ─── Azure Blob Storage ───────────────────────────────────────────────────────
AZURE_STORAGE_CONNECTION_STRING=         # From Azure Portal → Storage Account → Access keys
AZURE_BLOB_CONTAINER=reseller-docs

# ─── Azure Service Bus ────────────────────────────────────────────────────────
AZURE_SERVICE_BUS_CONNECTION_STRING=     # From Azure Portal → Service Bus → Shared access policies
AZURE_SERVICE_BUS_QUEUE_NAME=aeti-onboarding

# ─── NetSuite ─────────────────────────────────────────────────────────────────
NETSUITE_ACCOUNT_ID=                       # e.g. 1234567 — used for OAuth realm
NETSUITE_CONSUMER_KEY=
NETSUITE_CONSUMER_SECRET=
NETSUITE_TOKEN_ID=
NETSUITE_TOKEN_SECRET=
NETSUITE_RESTLET_URL=                      # Deployed Restlet script URL

# ─── Acrobat Sign ─────────────────────────────────────────────────────────────
ACROBAT_CLIENT_ID=                         # OAuth app client ID — used to verify webhook requests
ACROBAT_CLIENT_SECRET=
ACROBAT_REFRESH_TOKEN=
ACROBAT_API_BASE_URL=https://api.na1.adobesign.com
ACROBAT_NDA_TEMPLATE_ID=                   # Library document ID for the NDA template

# ─── SendGrid ─────────────────────────────────────────────────────────────────
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=resellers@pcsww.com
SENDGRID_FROM_NAME=PCS Partner Program
SENDGRID_TEMPLATE_WELCOME=               # Dynamic Template ID — welcome + NDA email
SENDGRID_TEMPLATE_INTERNAL_ALERT=        # Dynamic Template ID — ops alert email

# ─── Dashboard ────────────────────────────────────────────────────────────────
DASHBOARD_SECRET=                            # Token required in X-Dashboard-Secret header
JWT_SECRET=                                  # Random secret for signing dashboard JWTs
JWT_EXPIRES_IN=8h                            # Dashboard session length (default 8h)

# ─── PCS Internal ─────────────────────────────────────────────────────────────
PCS_OPS_EMAIL=ops@pcsww.com
PCS_LEGAL_EMAIL=legal@pcsww.com
PCS_LEGAL_NAME=PCS Legal Team

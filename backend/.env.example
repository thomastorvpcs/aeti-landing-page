# ─── Server ───────────────────────────────────────────────────────────────────
PORT=4000
NODE_ENV=development
ALLOWED_ORIGINS=http://localhost:3000

# ─── PostgreSQL ───────────────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=aeti_onboarding
DB_USER=aeti
DB_PASSWORD=aeti_dev

# ─── AWS (S3 + SQS) ───────────────────────────────────────────────────────────
# For local dev, LocalStack is used (docker-compose).
# In production, use IAM role credentials instead of access keys.
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test
AWS_ENDPOINT=http://localhost:4566       # Remove this in production
S3_BUCKET=aeti-reseller-docs
SQS_QUEUE_URL=http://localhost:4566/000000000000/aeti-onboarding

# ─── DocuSign ─────────────────────────────────────────────────────────────────
DOCUSIGN_ACCOUNT_ID=
DOCUSIGN_INTEGRATION_KEY=
DOCUSIGN_USER_ID=
DOCUSIGN_PRIVATE_KEY_PATH=./docusign.key   # RSA private key file for JWT Grant
DOCUSIGN_BASE_PATH=https://demo.docusign.net/restapi  # Change to prod URL when ready
DOCUSIGN_NDA_TEMPLATE_ID=                  # Template ID from DocuSign admin
DOCUSIGN_HMAC_SECRET=                      # From DocuSign Connect webhook config

# ─── NetSuite ─────────────────────────────────────────────────────────────────
NETSUITE_ACCOUNT_ID=                       # e.g. 1234567
NETSUITE_CONSUMER_KEY=
NETSUITE_CONSUMER_SECRET=
NETSUITE_TOKEN_ID=
NETSUITE_TOKEN_SECRET=
NETSUITE_SUBSIDIARY_ID=                    # Internal ID of subsidiary for new vendors
NETSUITE_LEGAL_EMPLOYEE_ID=               # Internal ID of PCS Legal employee
NETSUITE_FINANCE_EMPLOYEE_ID=             # Internal ID of PCS Finance employee
NETSUITE_FILE_CABINET_FOLDER_ID=          # File Cabinet folder for reseller docs

# ─── SendGrid ─────────────────────────────────────────────────────────────────
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=resellers@pcsww.com
SENDGRID_FROM_NAME=PCS Partner Program
SENDGRID_TEMPLATE_WELCOME=               # Dynamic Template ID — welcome + NDA email
SENDGRID_TEMPLATE_INTERNAL_ALERT=        # Dynamic Template ID — ops alert email

# ─── PCS Internal ─────────────────────────────────────────────────────────────
PCS_OPS_EMAIL=ops@pcsww.com
PCS_LEGAL_EMAIL=legal@pcsww.com
PCS_LEGAL_NAME=PCS Legal Team

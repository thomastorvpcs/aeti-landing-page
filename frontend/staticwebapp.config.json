{
  "routes": [
    {
      "route": "/api/*",
      "rewrite": "https://abti-api.azurewebsites.net/api/*"
    },
    {
      "route": "/acrobat/*",
      "rewrite": "https://abti-api.azurewebsites.net/acrobat/*"
    },
    {
      "route": "/*",
      "serve": "/index.html",
      "statusCode": 200
    }
  ],
  "navigationFallback": {
    "rewrite": "/index.html",
    "exclude": ["/assets/*", "/*.{css,js,png,jpg,svg,ico}"]
  }
}
